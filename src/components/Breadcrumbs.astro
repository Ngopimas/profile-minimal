---
// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);

const sectionLabels: Record<string, string> = {
  projects: "Work",
  posts: "Writing",
  tags: "Topics",
};

// if breadcrumb is Home > Writing > 2 <etc>
// replace Writing > page with Writing (page number)
breadcrumbList[0] === "posts" &&
  breadcrumbList[1] &&
  breadcrumbList.splice(0, 2, `Writing (page ${breadcrumbList[1]})`);

breadcrumbList[0] === "projects" &&
  breadcrumbList[1] &&
  breadcrumbList.splice(0, 2, `Work (page ${breadcrumbList[1]})`);

// if breadcrumb is Home > Topics > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (page number)
breadcrumbList[0] === "tags" &&
  !isNaN(Number(breadcrumbList[2])) &&
  breadcrumbList.splice(
    1,
    3,
    `${breadcrumbList[1]} ${
      Number(breadcrumbList[2]) === 1 ? "" : "(page " + breadcrumbList[2] + ")"
    }`
  );

function getBreadcrumbLabel(breadcrumb: string) {
  return sectionLabels[breadcrumb] ?? breadcrumb;
}

function getBreadcrumbHref(breadcrumb: string) {
  const sectionEntry = Object.entries(sectionLabels).find(
    ([, label]) => label === breadcrumb
  );

  return `/${sectionEntry?.[0] ?? breadcrumb}/`;
}
---

<nav class="breadcrumb" aria-label="breadcrumb">
  <ul>
    <li>
      <a href="/">Home</a>
      <span aria-hidden="true">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class={`${index > 0 ? "lowercase" : "capitalize"}`}
              aria-current="page"
            >
              {/* make the last part lowercase in Home > Topics > some-tag */}
              {decodeURIComponent(getBreadcrumbLabel(breadcrumb))}
            </span>
          </li>
        ) : (
          <li>
            <a href={getBreadcrumbHref(breadcrumb)}>
              {getBreadcrumbLabel(breadcrumb)}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ul>
</nav>

<style>
  .breadcrumb {
    @apply mx-auto mb-1 mt-8 w-full max-w-4xl px-6;
  }
  .breadcrumb ul li {
    @apply inline;
  }
  .breadcrumb ul li a {
    @apply capitalize;
  }
  .breadcrumb ul li span {
    @apply opacity-70;
  }
  .breadcrumb ul li:not(:last-child) a {
    @apply hover:opacity-100;
  }
</style>
