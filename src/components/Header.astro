---
import { LOGO_IMAGE, SITE } from "@config";
import Hr from "./Hr.astro";
import LinkButton from "./LinkButton.astro";

export interface Props {
  activeNav?: "projects" | "posts" | "archives" | "tags" | "about" | "search";
}

const { activeNav } = Astro.props;
---

<header class="sticky top-0 z-10 backdrop-blur-md">
  <a id="skip-to-content" href="#main-content">Skip to content</a>
  <div class="nav-container">
    <div class="top-nav-wrap">
      <a href="/" class="logo whitespace-nowrap">
        {
          LOGO_IMAGE.enable ? (
            <img
              src={`/assets/${LOGO_IMAGE.svg ? "logo.svg" : "logo.png"}`}
              alt={SITE.title}
              width={LOGO_IMAGE.width}
              height={LOGO_IMAGE.height}
            />
          ) : (
            SITE.title
          )
        }
      </a>
      <nav id="nav-menu">
        <ul id="menu-items" class="flex">
          <li>
            <a
              href="/projects/"
              class:list={[{ active: activeNav === "projects" }]}
            >
              Work
            </a>
          </li>
          <li>
            <a href="/posts/" class:list={[{ active: activeNav === "posts" }]}>
              Writing
            </a>
          </li>
          <li>
            <a href="/tags/" class:list={[{ active: activeNav === "tags" }]}>
              Tags
            </a>
          </li>
          <li>
            <LinkButton
              href="/search/"
              className={`focus-outline p-2 ${
                activeNav === "search" ? "active" : ""
              } icon-link flex`}
              ariaLabel="search"
              title="Search"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="nav-icon h-5 w-5"
                ><path
                  d="M19.023 16.977a35.13 35.13 0 0 1-1.367-1.384c-.372-.378-.596-.653-.596-.653l-2.8-1.337A6.962 6.962 0 0 0 16 9c0-3.859-3.14-7-7-7S2 5.141 2 9s3.14 7 7 7c1.763 0 3.37-.66 4.603-1.739l1.337 2.8s.275.224.653.596c.387.363.896.854 1.384 1.367l1.358 1.392.604.646 2.121-2.121-.646-.604c-.379-.372-.885-.866-1.391-1.36zM9 14c-2.757 0-5-2.243-5-5s2.243-5 5-5 5 2.243 5 5-2.243 5-5 5z"
                ></path>
              </svg>
              <span class="sr-only">Search</span>
            </LinkButton>
          </li>
          {
            SITE.lightAndDarkMode && (
              <li>
                <button
                  id="theme-btn"
                  class="focus-outline icon-link p-2"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    id="moon-svg"
                    class="nav-icon h-5 w-5"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <path d="M20.742 13.045a8.088 8.088 0 0 1-2.077.271c-2.135 0-4.14-.83-5.646-2.336a8.025 8.025 0 0 1-2.064-7.723A1 1 0 0 0 9.73 2.034a10.014 10.014 0 0 0-4.489 2.582c-3.898 3.898-3.898 10.243 0 14.143a9.937 9.937 0 0 0 7.072 2.93 9.93 9.93 0 0 0 7.07-2.929 10.007 10.007 0 0 0 2.583-4.491 1.001 1.001 0 0 0-1.224-1.224zm-2.772 4.301a7.947 7.947 0 0 1-5.656 2.343 7.953 7.953 0 0 1-5.658-2.344c-3.118-3.119-3.118-8.195 0-11.314a7.923 7.923 0 0 1 2.06-1.483 10.027 10.027 0 0 0 2.89 7.848 9.972 9.972 0 0 0 7.848 2.891 8.036 8.036 0 0 1-1.484 2.059z" />
                  </svg>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    id="sun-svg"
                    class="nav-icon h-5 w-5"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <path d="M12 3a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V4a1 1 0 0 1 1-1zm4.22 1.78a1 1 0 0 1 1.42 0l.7.71a1 1 0 1 1-1.42 1.42l-.7-.71a1 1 0 0 1 0-1.42zM21 11a1 1 0 0 1 0 2h-1a1 1 0 0 1 0-2h1zM17.3 17.3a1 1 0 0 1 0 1.42l-.71.7a1 1 0 1 1-1.42-1.42l.71-.7a1 1 0 0 1 1.42 0zM12 17a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1zM6.7 17.3a1 1 0 0 1 1.42 0l.7.71a1 1 0 1 1-1.42 1.42l-.7-.71a1 1 0 0 1 0-1.42zM4 11a1 1 0 0 1 0 2H3a1 1 0 0 1 0-2h1zM5.08 5.78a1 1 0 0 1 0 1.42l-.71.7a1 1 0 0 1-1.42-1.42l.71-.71a1 1 0 0 1 1.42 0zM12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10z" />
                  </svg>
                </button>
              </li>
            )
          }
        </ul>
      </nav>
    </div>
  </div>
  <Hr />
</header>

<style>
  #skip-to-content {
    @apply absolute -top-full left-16 z-50 bg-skin-accent px-3 py-2 text-skin-inverted transition-all focus:top-4;
  }
  .nav-container {
    @apply mx-auto flex max-w-4xl flex-col items-center justify-between sm:flex-row;
  }
  .top-nav-wrap {
    @apply relative flex w-full items-center justify-between px-6 py-6 sm:py-8;
  }
  .logo {
    @apply py-1 font-display text-lg font-medium tracking-tight hover:text-skin-accent sm:text-xl;
  }

  nav {
    @apply flex items-center;
  }
  nav ul {
    @apply flex items-center gap-1 sm:gap-2;
  }
  nav ul li a {
    @apply px-3 py-2 text-sm font-medium text-skin-base/70 transition-colors hover:text-skin-base;
  }
  nav .active {
    @apply text-skin-base;
  }

  .nav-icon {
    @apply h-5 w-5;
  }

  #theme-btn {
    @apply p-2;
  }
  #theme-btn svg {
    @apply transition-opacity hover:opacity-70;
  }
</style>

<script>
  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", () => {
    // Theme toggle is handled by toggle-theme.js
  });
</script>
