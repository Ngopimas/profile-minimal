---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import ProjectCard from "@components/ProjectCard";
import getSortedPosts from "@utils/getSortedPosts";
import { SITE, SOCIALS } from "@config";
import getReadingTime from "@utils/getReadingTime";
import getEntrySlug from "@utils/getEntrySlug";

const posts = await getCollection("blog");
const projects = await getCollection("projects");

const sortedPosts = getSortedPosts(posts);
const sortedProjects = getSortedPosts(projects);
const featuredProjects = sortedProjects.filter(({ data }) => data.featured);

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout title="Romain C. - Web Applications & Autonomous Systems">
  <Header />
  <main id="main-content">
    <section id="hero" class="mx-auto max-w-4xl">
      <h1
        class="heading animate-slide-up text-4xl font-medium md:text-5xl lg:text-6xl"
      >
        Software that shows its work.
      </h1>
      <div class="hero-container">
        <div class="hero-content stagger-appear">
          <p class="text-lg text-skin-base">
            Software engineer at <LinkButton
              href="https://www.omaha-insights.com/"
              className="text-skin-accent underline-offset-4 hover:underline hover:opacity-80"
              title="Omaha Insights website"
              target="_blank"
              rel="noopener noreferrer">Omaha Insights</LinkButton
            >. Autonomous research pipelines, data visualizations, and web
            applications.
          </p>
          <p class="mt-8 text-skin-base/75">
            <span
              class="mb-1 block text-xs font-semibold uppercase tracking-widest text-skin-base/40"
              >Current focus</span
            >
            agentic systems for equity research, backtest-driven strategy selection,
            and interfaces that expose their own reasoning.
          </p>
          {
            socialCount > 0 && (
              <div class="flex items-center gap-4 pt-2">
                <Socials />
              </div>
            )
          }
        </div>
      </div>
    </section>

    {
      featuredProjects.length > 0 && (
        <section class="mx-auto max-w-4xl py-16">
          <div class="mb-10">
            <h2 class="font-display text-3xl font-medium tracking-tight">
              Selected Work
            </h2>
            <p class="mt-3 max-w-2xl text-skin-base/60">
              AI systems, autonomous research tooling, data visualizations, and
              production web applications.
            </p>
          </div>
          <div class="divide-y divide-skin-line">
            {featuredProjects.map(
              (project, index) =>
                index < SITE.postPerIndex && (
                  <ProjectCard
                    href={`/projects/${getEntrySlug(project)}/`}
                    frontmatter={project.data}
                    secHeading={false}
                  />
                )
            )}
          </div>
          <div class="mt-8">
            <LinkButton
              href="/projects/"
              className="text-sm font-medium text-skin-base/60 hover:text-skin-accent transition-colors"
            >
              View more →
            </LinkButton>
          </div>
        </section>
      )
    }

    {
      sortedPosts.length > 0 && (
        <section class="mx-auto max-w-4xl py-16">
          <div class="mb-10">
            <h2 class="font-display text-3xl font-medium tracking-tight">
              Writing
            </h2>
            <p class="mt-3 max-w-2xl text-skin-base/60">
              Field notes from building AI-assisted research systems,
              dashboards, and production web apps.
            </p>
          </div>
          <div class="divide-y divide-skin-line">
            {sortedPosts.map(
              (post, index) =>
                index < SITE.postPerIndex && (
                  <Card
                    href={`/posts/${getEntrySlug(post)}/`}
                    frontmatter={post.data}
                    secHeading={false}
                    readingTime={getReadingTime(post.body)}
                  />
                )
            )}
          </div>
          <div class="mt-8">
            <LinkButton
              href="/posts/"
              className="text-sm font-medium text-skin-base/60 hover:text-skin-accent transition-colors"
            >
              Read more →
            </LinkButton>
          </div>
        </section>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  main {
    @apply relative;
  }

  /* ===== Hero Section ===== */
  #hero {
    @apply pb-16 pt-12;
  }

  .hero-container {
    @apply flex flex-col items-start justify-between gap-8;
    position: relative;
    z-index: 2;
  }

  #hero h1 {
    @apply mb-6 inline-block;
  }

  .hero-content {
    @apply max-w-2xl flex-1;
  }
  #hero p {
    @apply my-3;
  }
</style>
