---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import ProjectCard from "@components/ProjectCard";
import getSortedPosts from "@utils/getSortedPosts";
import { SITE, SOCIALS } from "@config";
import getReadingTime from "@utils/getReadingTime";
import getEntrySlug from "@utils/getEntrySlug";

const posts = await getCollection("blog");
const projects = await getCollection("projects");

const sortedPosts = getSortedPosts(posts);
const sortedProjects = getSortedPosts(projects);
const featuredProjects = sortedProjects.filter(({ data }) => data.featured);

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout title="Romain C. - Autonomous Systems & Quantitative Research">
  <Header />
  <main id="main-content">
    <section id="hero" class="mx-auto max-w-4xl">
      <h1 class="heading text-4xl font-medium md:text-5xl lg:text-6xl">
        Software that shows its work.
      </h1>
      <div class="hero-container">
        <div class="hero-content">
          <p class="text-lg text-skin-base/80">
            Software engineer at <LinkButton
              href="https://www.omaha-insights.com/"
              className="text-skin-accent underline-offset-4 hover:underline hover:opacity-80"
              title="Omaha Insights website"
              target="_blank"
              rel="noopener noreferrer">Omaha Insights</LinkButton
            >. Autonomous research pipelines, data visualizations, and web applications.
          </p>
          <p class="text-skin-base/60">
            Current focus: agentic systems for equity research, backtest-driven strategy selection, and interfaces that expose their own reasoning.
          </p>
          {
            socialCount > 0 && (
              <div class="flex items-center gap-4 pt-2">
                <Socials />
              </div>
            )
          }
        </div>
      </div>
    </section>

    {
      featuredProjects.length > 0 && (
        <section class="mx-auto max-w-4xl py-16">
          <div class="mb-10 flex items-baseline justify-between">
            <h2 class="font-display text-2xl font-medium tracking-tight">Selected Work</h2>
            <LinkButton
              href="/projects/"
              className="text-sm text-skin-base/50 hover:text-skin-accent transition-colors"
            >
              View all
            </LinkButton>
          </div>
          <div class="divide-y divide-skin-line">
            {featuredProjects.map(
              (project, index) =>
                index < SITE.postPerIndex && (
                  <ProjectCard
                    href={`/projects/${getEntrySlug(project)}/`}
                    frontmatter={project.data}
                    secHeading={false}
                  />
                )
            )}
          </div>
        </section>
      )
    }

    {
      sortedPosts.length > 0 && (
        <section class="mx-auto max-w-4xl py-16">
          <div class="mb-10 flex items-baseline justify-between">
            <h2 class="font-display text-2xl font-medium tracking-tight">Writing</h2>
            <LinkButton
              href="/posts/"
              className="text-sm text-skin-base/50 hover:text-skin-accent transition-colors"
            >
              View all
            </LinkButton>
          </div>
          <div class="divide-y divide-skin-line">
            {sortedPosts.map(
              (post, index) =>
                index < SITE.postPerIndex && (
                  <Card
                    href={`/posts/${getEntrySlug(post)}/`}
                    frontmatter={post.data}
                    secHeading={false}
                    readingTime={getReadingTime(post.body)}
                  />
                )
            )}
          </div>
        </section>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  main {
    @apply relative;
  }

  /* ===== Hero Section ===== */
  #hero {
    @apply pb-12 pt-8;
  }

  .hero-container {
    @apply flex flex-col items-start justify-between gap-8;
    position: relative;
    z-index: 2;
  }

  #hero h1 {
    @apply mb-6 inline-block max-w-3xl;
  }

  .hero-content {
    @apply flex-1 max-w-2xl;
  }
  #hero p {
    @apply my-3;
  }
</style>
