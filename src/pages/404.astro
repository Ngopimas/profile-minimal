---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
---

<Layout title={`404 | ${SITE.title}`}>
  <Header />

  <main id="main-content">
    <div class="not-found-wrapper">
      <h1>404</h1>
      <p>This page does not exist.</p>
      <LinkButton
        href="/"
        className="mt-8 text-sm text-skin-base/60 hover:text-skin-accent transition-colors"
      >
        Return home
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  #main-content {
    @apply mx-auto flex max-w-4xl flex-1 items-center justify-center px-6;
  }
  .not-found-wrapper {
    @apply mb-14 flex flex-col items-center justify-center;
  }
  .not-found-wrapper h1 {
    @apply text-8xl font-medium text-skin-base/10;
  }
  .not-found-wrapper p {
    @apply mt-2 text-lg text-skin-base/60;
  }
</style>
